# GitHub Packages registry for the @porksphere scope.
# The real business-logic core (@porksphere/core) is published from its own repo
# to GitHub Packages. Until then, a local workspace stub in packages/core resolves
# this dependency. When the published core exists, delete packages/core and remove
# it from the workspaces list — this .npmrc then makes `npm ci` fetch the registry version.
#
# Auth: set NODE_AUTH_TOKEN to a token with read:packages on the core repo.
#   - locally:  export NODE_AUTH_TOKEN=$(gh auth token)   (or a PAT)
#   - in CI:    NODE_AUTH_TOKEN: ${{ secrets.GITHUB_TOKEN }}  (or a fine-grained PAT)
@porksphere:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
